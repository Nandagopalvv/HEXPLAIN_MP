# Hexplain Environment Configuration
# Copy this file to .env and fill in your API keys

# ── VirusTotal API ──
# Get a FREE API key at: https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute, 500 requests/day
# The malware scanner will work without this key using behavioral analysis only.
VIRUSTOTAL_API_KEY=your_vt_api_key_here

# ── OpenAI (optional — only if using cloud LLM instead of local Ollama) ──
# OPENAI_API_KEY=your_openai_api_key_here

# ── Hexplain Model Settings (optional) ──
# HEXPLAIN_MODEL=llama3.2
# HEXPLAIN_PROVIDER=local
